# Creative Hotline Command Center — Environment Variables
# Copy this file to .env.local and fill in your API keys.

# App Mode (set to "false" for live data)
NEXT_PUBLIC_DEMO_MODE=true

# Notion CRM
NOTION_API_KEY=secret_...
NOTION_PAYMENTS_DB=3030e73ffadc80bcb9dde15f51a9caf2
NOTION_INTAKE_DB=2f60e73ffadc806bbf5ddca2f5c256a3

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Calendly
CALENDLY_API_KEY=
CALENDLY_ORG_URI=https://api.calendly.com/organizations/...
CALENDLY_USER_URI=https://api.calendly.com/users/...

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# n8n
N8N_BASE_URL=https://creativehotline.app.n8n.cloud
N8N_API_KEY=
N8N_WORKSHOP_WEBHOOK_URL=https://creativehotline.app.n8n.cloud/webhook/workshop-followups

# ManyChat
MANYCHAT_API_KEY=

# Fireflies
FIREFLIES_API_KEY=

# Workshop
WORKSHOP_ENABLED=true

# Tally (Creative Hotline Intake form b5W1JE)
# HMAC secret from Tally → form b5W1JE → Integrations → Webhooks. Required in
# production. Verifies inbound POST /api/tally/webhook signatures.
TALLY_WEBHOOK_SECRET=
# Set to "true" only in local dev when you want to POST hand-crafted JSON
# without a signature. MUST stay unset (or "false") in production.
TALLY_ALLOW_UNSIGNED=false
